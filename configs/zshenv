# =============================================================================
# ~/.zshenv — Zsh environment variables (sourced for ALL zsh invocations)
# =============================================================================
# cli-bootstrap — Production-quality CLI environment
# WARNING: Keep this file fast. No commands, no output.
# =============================================================================

# ---------------------------------------------------------------------------
# XDG BASE DIRECTORY SPECIFICATION
# ---------------------------------------------------------------------------
export XDG_CONFIG_HOME="${HOME}/.config"
export XDG_DATA_HOME="${HOME}/.local/share"
export XDG_CACHE_HOME="${HOME}/.cache"
export XDG_STATE_HOME="${HOME}/.local/state"

# ---------------------------------------------------------------------------
# PATH — ordered from highest to lowest priority
# ---------------------------------------------------------------------------
typeset -U path  # Unique entries only

path=(
  "${HOME}/.local/bin"
  "${HOME}/.cargo/bin"
  "${HOME}/go/bin"
  "${HOME}/.go/bin"
  "${HOME}/.npm-global/bin"
  "${HOME}/.composer/vendor/bin"
  "${HOME}/.config/composer/vendor/bin"
  "${HOME}/.symfony/bin"
  "/usr/local/bin"
  "/usr/local/sbin"
  "/usr/bin"
  "/usr/sbin"
  "/bin"
  "/sbin"
  "${path[@]}"
)

export PATH

# ---------------------------------------------------------------------------
# DEFAULT PROGRAMS
# ---------------------------------------------------------------------------
export EDITOR="${EDITOR:-nvim}"
export VISUAL="${VISUAL:-${EDITOR}}"

# Pager — use bat if available, fallback to less
if command -v bat &>/dev/null 2>&1; then
  export PAGER="bat --style=plain --paging=always"
  export MANPAGER="sh -c 'col -bx | bat --language=man --style=plain --paging=always'"
elif command -v batcat &>/dev/null 2>&1; then
  export PAGER="batcat --style=plain --paging=always"
  export MANPAGER="sh -c 'col -bx | batcat --language=man --style=plain --paging=always'"
else
  export PAGER="less -R"
  export MANPAGER="${PAGER}"
fi

# ---------------------------------------------------------------------------
# LANGUAGE / LOCALE
# ---------------------------------------------------------------------------
export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"
export LC_CTYPE="${LC_CTYPE:-en_US.UTF-8}"

# ---------------------------------------------------------------------------
# TERMINAL
# ---------------------------------------------------------------------------
export TERM="${TERM:-xterm-256color}"
export COLORTERM="${COLORTERM:-truecolor}"

# ---------------------------------------------------------------------------
# HISTORY
# ---------------------------------------------------------------------------
export HISTFILE="${XDG_STATE_HOME}/zsh/history"
export HISTSIZE=1000000
export SAVEHIST=1000000

# ---------------------------------------------------------------------------
# BAT
# ---------------------------------------------------------------------------
export BAT_THEME="Catppuccin Macchiato"
export BAT_STYLE="numbers,changes,header"

# ---------------------------------------------------------------------------
# FZF — Default options
# ---------------------------------------------------------------------------
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS="
  --height=60%
  --layout=reverse
  --border=rounded
  --prompt='❯ '
  --pointer='▶'
  --marker='✔'
  --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8
  --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc
  --color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8
  --info=inline
  --cycle
  --bind='ctrl-/:toggle-preview'
  --bind='ctrl-u:preview-half-page-up'
  --bind='ctrl-d:preview-half-page-down'
  --bind='alt-j:preview-down'
  --bind='alt-k:preview-up'
"
export FZF_CTRL_T_OPTS="
  --preview 'bat --color=always --style=numbers --line-range=:500 {}'
  --preview-window='right:60%:wrap'
"
export FZF_ALT_C_OPTS="
  --preview 'eza --tree --color=always {} | head -100'
"
export FZF_CTRL_R_OPTS="
  --preview 'echo {}'
  --preview-window=down:3:hidden:wrap
  --bind='ctrl-/:toggle-preview'
  --sort
  --exact
"

# ---------------------------------------------------------------------------
# RIPGREP
# ---------------------------------------------------------------------------
export RIPGREP_CONFIG_PATH="${XDG_CONFIG_HOME}/ripgrep/config"

# ---------------------------------------------------------------------------
# LESS
# ---------------------------------------------------------------------------
export LESS='-R -F -X -g -i -M -S -z-4'
export LESSHISTFILE="${XDG_STATE_HOME}/less/history"

# ---------------------------------------------------------------------------
# GO
# ---------------------------------------------------------------------------
export GOPATH="${HOME}/go"
export GOBIN="${GOPATH}/bin"

# ---------------------------------------------------------------------------
# RUST / CARGO
# ---------------------------------------------------------------------------
export CARGO_HOME="${HOME}/.cargo"

# ---------------------------------------------------------------------------
# NODE
# ---------------------------------------------------------------------------
export NPM_CONFIG_PREFIX="${HOME}/.npm-global"
export NODE_REPL_HISTORY="${XDG_STATE_HOME}/node/history"

# ---------------------------------------------------------------------------
# PYTHON
# ---------------------------------------------------------------------------
export PYTHONSTARTUP="${XDG_CONFIG_HOME}/python/startup.py"
export VIRTUAL_ENV_DISABLE_PROMPT=1  # Starship handles this

# ---------------------------------------------------------------------------
# DOCKER
# ---------------------------------------------------------------------------
export DOCKER_CONFIG="${XDG_CONFIG_HOME}/docker"
export COMPOSE_DOCKER_CLI_BUILD=1
export DOCKER_BUILDKIT=1

# ---------------------------------------------------------------------------
# COMPOSER
# ---------------------------------------------------------------------------
export COMPOSER_HOME="${HOME}/.composer"
export COMPOSER_MEMORY_LIMIT=-1

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
export AWS_CONFIG_FILE="${XDG_CONFIG_HOME}/aws/config"
export AWS_SHARED_CREDENTIALS_FILE="${XDG_CONFIG_HOME}/aws/credentials"

# ---------------------------------------------------------------------------
# GPG
# ---------------------------------------------------------------------------
export GPG_TTY="$(tty)"

# ---------------------------------------------------------------------------
# DIRENV
# ---------------------------------------------------------------------------
export DIRENV_LOG_FORMAT=""  # Silence direnv output

# ---------------------------------------------------------------------------
# ZOXIDE
# ---------------------------------------------------------------------------
export _ZO_DATA_DIR="${XDG_DATA_HOME}/zoxide"
export _ZO_ECHO=1  # Print matched dir when jumping

# ---------------------------------------------------------------------------
# ATUIN
# ---------------------------------------------------------------------------
export ATUIN_SESSION="$(uuidgen 2>/dev/null | tr '[:upper:]' '[:lower:]' | tr -d '-' || date +%s%N)"
